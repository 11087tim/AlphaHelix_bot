# X (Twitter) API v2 - Basic 方案取得的 Bearer Token
# https://developer.x.com/en/portal/products
X_BEARER_TOKEN=

# OpenRouter API key
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Gmail 寄信帳號與 App Password（需先開啟兩步驟驗證後產生）
# https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Groq API key（選用：長訪談 Podcast 轉錄用 Whisper）
# https://console.groq.com/keys
GROQ_API_KEY=
