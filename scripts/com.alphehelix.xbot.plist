<?xml version="1.0" encoding="UTF-8"?>
<!--
  安裝方式：
    1. 依你的實際路徑修改下方 __PROJECT_DIR__（專案資料夾）與 __PYTHON__（venv 內的 python）。
    2. cp scripts/com.alphehelix.xbot.plist ~/Library/LaunchAgents/
    3. launchctl load ~/Library/LaunchAgents/com.alphehelix.xbot.plist
  排程時間依 Mac 系統本地時區，請確認系統時區為 Asia/Taipei。
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alphehelix.xbot</string>

    <key>ProgramArguments</key>
    <array>
        <string>__PYTHON__</string>
        <string>-m</string>
        <string>src.main</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Hour</key><integer>8</integer>
            <key>Minute</key><integer>0</integer>
        </dict>
        <dict>
            <key>Hour</key><integer>15</integer>
            <key>Minute</key><integer>0</integer>
        </dict>
        <dict>
            <key>Hour</key><integer>20</integer>
            <key>Minute</key><integer>30</integer>
        </dict>
    </array>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/xbot.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/xbot.log</string>
</dict>
</plist>
